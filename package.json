    "mcp-tracking",
    "llm-observability",
    "cost-tracking",
    "ai-monitoring",
    "agent-budget",
    "llm-logging",
    "ai-analytics",
    "openai",
    "anthropic",
    "groq",
    "mcp",
    "autonomous-agents",
    "ai-infrastructure"
  ],
  "author": "Brennan Zambo <brennanzambo@zambo.dev> (https://zambo.dev)",
